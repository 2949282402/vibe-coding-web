<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hejulian.blog.mapper.UserAccountMapper">

    <resultMap id="UserAccountResultMap" type="com.hejulian.blog.entity.UserAccount">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
        <result property="displayName" column="display_name"/>
        <result property="role" column="role"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="selectByUsername" resultMap="UserAccountResultMap">
        SELECT id, username, password, display_name, role, created_at, updated_at
        FROM user_accounts
        WHERE username = #{username}
        LIMIT 1
    </select>

    <select id="countAll" resultType="long">
        SELECT COUNT(1) FROM user_accounts
    </select>

    <insert id="insert" parameterType="com.hejulian.blog.entity.UserAccount" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user_accounts (username, password, display_name, role, created_at, updated_at)
        VALUES (#{username}, #{password}, #{displayName}, #{role}, CURRENT_TIMESTAMP, CURRENT_TIMESTAMP)
    </insert>

</mapper>

