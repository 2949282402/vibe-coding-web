<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hejulian.blog.mapper.RagChunkMapper">

    <resultMap id="RagChunkResultMap" type="com.hejulian.blog.entity.RagChunk">
        <id property="id" column="id"/>
        <result property="postId" column="post_id"/>
        <result property="postTitle" column="post_title"/>
        <result property="postSlug" column="post_slug"/>
        <result property="chunkIndex" column="chunk_index"/>
        <result property="content" column="content"/>
        <result property="contentHash" column="content_hash"/>
        <result property="embeddingJson" column="embedding_json"/>
        <result property="embeddingModel" column="embedding_model"/>
        <result property="embeddingDimensions" column="embedding_dimensions"/>
        <result property="publishedAt" column="published_at"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="countAll" resultType="long">
        SELECT COUNT(1) FROM rag_chunks
    </select>

    <select id="countWithoutEmbedding" resultType="long">
        SELECT COUNT(1)
        FROM rag_chunks
        WHERE embedding_json IS NULL OR embedding_json = ''
    </select>

    <select id="selectAll" resultMap="RagChunkResultMap">
        SELECT id, post_id, post_title, post_slug, chunk_index, content, content_hash,
               embedding_json, embedding_model, embedding_dimensions,
               published_at, created_at, updated_at
        FROM rag_chunks
        ORDER BY published_at DESC, post_id DESC, chunk_index ASC
    </select>

    <delete id="deleteAll">
        DELETE FROM rag_chunks
    </delete>

    <delete id="deleteByPostId">
        DELETE FROM rag_chunks
        WHERE post_id = #{postId}
    </delete>

    <insert id="batchInsert">
        INSERT INTO rag_chunks (
            post_id, post_title, post_slug, chunk_index, content, content_hash,
            embedding_json, embedding_model, embedding_dimensions,
            published_at, created_at, updated_at
        ) VALUES
        <foreach collection="chunks" item="chunk" separator=",">
            (
                #{chunk.postId},
                #{chunk.postTitle},
                #{chunk.postSlug},
                #{chunk.chunkIndex},
                #{chunk.content},
                #{chunk.contentHash},
                #{chunk.embeddingJson},
                #{chunk.embeddingModel},
                #{chunk.embeddingDimensions},
                #{chunk.publishedAt},
                CURRENT_TIMESTAMP,
                CURRENT_TIMESTAMP
            )
        </foreach>
    </insert>

</mapper>
