MYSQL_DATABASE=hejulian_blog
MYSQL_USER=hejulian_blog
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=root_change_me
MYSQL_PORT=3306
REDIS_PORT=6379
BACKEND_PORT=8080
FRONTEND_PORT=80
MYSQL_MEM_LIMIT=384m
MYSQL_CPUS=0.40
MYSQL_INNODB_BUFFER_POOL_SIZE=128M
MYSQL_MAX_CONNECTIONS=40
MYSQL_TABLE_OPEN_CACHE=128
REDIS_MEM_LIMIT=192m
REDIS_CPUS=0.20
REDIS_APPENDONLY=yes
REDIS_MAXMEMORY=128mb
REDIS_MAXMEMORY_POLICY=allkeys-lru
QDRANT_MEM_LIMIT=320m
QDRANT_CPUS=0.35
QDRANT_MAX_WORKERS=1
QDRANT_ON_DISK_PAYLOAD=true
QDRANT_HNSW_ON_DISK=true
LLM_BRIDGE_MEM_LIMIT=160m
LLM_BRIDGE_CPUS=0.15
BACKEND_MEM_LIMIT=700m
BACKEND_CPUS=0.70
FRONTEND_MEM_LIMIT=96m
FRONTEND_CPUS=0.15
JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=62 -XX:InitialRAMPercentage=20 -XX:MaxMetaspaceSize=128m -XX:+UseSerialGC -XX:+ExitOnOutOfMemoryError
BLOG_RAG_GENERATOR_ENABLED=false
BLOG_RAG_EMBEDDING_ENABLED=false
BLOG_RAG_RERANK_ENABLED=false
BLOG_RAG_QDRANT_ENABLED=false
BLOG_RAG_PYTHON_BRIDGE_ENABLED=false
BLOG_RAG_PYTHON_BRIDGE_BASE_URL=http://host.docker.internal:8090
BLOG_RAG_PYTHON_BRIDGE_TIMEOUT_SECONDS=600
BLOG_RAG_STREAM_TIMEOUT_MILLIS=900000
BLOG_RAG_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BLOG_RAG_API_KEY=
BLOG_RAG_MODEL=qwen-max
BLOG_RAG_GENERATOR_TIMEOUT_SECONDS=180
BLOG_RAG_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BLOG_RAG_EMBEDDING_API_KEY=
BLOG_RAG_EMBEDDING_MODEL=text-embedding-v4
BLOG_RAG_EMBEDDING_DIMENSIONS=1024
BLOG_RAG_EMBEDDING_BATCH_SIZE=10
BLOG_RAG_RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1
BLOG_RAG_RERANK_API_KEY=
BLOG_RAG_RERANK_MODEL=qwen3-rerank
BLOG_RAG_QDRANT_BASE_URL=http://qdrant:6333
BLOG_RAG_QDRANT_API_KEY=
BLOG_RAG_QDRANT_COLLECTION=blog_knowledge_chunks
BLOG_RAG_QDRANT_TIMEOUT_SECONDS=10
BLOG_RAG_QDRANT_ON_DISK_PAYLOAD=true
BLOG_RAG_RECALL_MULTIPLIER=4
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_TIMEOUT_SECONDS=600
LLM_BRIDGE_PORT=8090
BLOG_RAG_TOP_K=4
BLOG_RAG_CHUNK_SIZE=520
BLOG_RAG_CHUNK_OVERLAP=120
